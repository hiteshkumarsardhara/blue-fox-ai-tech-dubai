# Database — dev uses SQLite. For production use a PostgreSQL connection string
# (and switch the datasource provider + adapter).
DATABASE_URL="file:./dev.db"

# Session signing secret — generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="change-me-in-production"

# Email (optional). Without RESEND_API_KEY, emails are logged to the server
# console (dev). Set both to send real emails via Resend (https://resend.com).
# MAIL_FROM must use a domain you've verified in Resend.
# RESEND_API_KEY="re_..."
# MAIL_FROM="Blue Fox Dubai <no-reply@yourdomain.com>"
